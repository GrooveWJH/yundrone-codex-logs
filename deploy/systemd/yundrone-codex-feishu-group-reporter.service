[Unit]
Description=YunDrone Feishu Scheduled Group Reporter
After=network.target

[Service]
Type=simple
User=groove
Group=groove
WorkingDirectory=/home/groove/apps/yundrone-codex-logs
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/groove/apps/yundrone-codex-logs/.venv/bin/python -m scripts.run_feishu_group_reporter
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
